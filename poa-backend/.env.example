# POA Backend 环境变量
# 复制此文件为 .env 并填入实际值（.env 不会被提交到 git）

# 豆包 API（必填）
DOUBAO_API_KEY=ark-your-api-key-here
DOUBAO_MODEL_ID=doubao-seed-2-0-mini-260428
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# Ark SDK（可选，默认复用 DOUBAO_API_KEY）
ARK_API_KEY=
ARK_MODEL_ID=doubao-1.5-vision-pro-32k

# 数据库（可选，默认 SQLite）
# Railway 上自动检测 /data 目录并存入持久卷
# 也可使用 PostgreSQL: postgresql://user:pass@host:5432/dbname
DATABASE_URL=

# 上传文件目录（可选）
# 本地默认: uploads/
# Railway: 自动检测 /data 目录
UPLOAD_DIR=

# 服务端口（Railway 自动注入 $PORT）
PORT=8000

# 豆包 TTS 语音合成（可选）
# 两种鉴权方式二选一：
#   方式A（推荐）：直接复用上方 DOUBAO_API_KEY，代码自动尝试 X-Api-Key 模式
#   方式B（Legacy）：在火山引擎控制台「语音技术」获取 APP_ID + Token
# DOUBAO_TTS_APP_ID=
# DOUBAO_TTS_TOKEN=
# DOUBAO_TTS_VOICE=en_female_dacey_uranus_bigtts
# DOUBAO_TTS_RESOURCE_ID=seed-tts-2.0

# ASR 语音转写（可选，默认本地启用，Railway 禁用）
# ASR_ENABLED=1
